  {
    "name": "get_attachments",
    "description": "Get attachments for a message. Without attachment_id: list all metadata. With attachment_id: download that attachment (base64 if under 1.5 MB).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "attachment_id": {
          "type": "string",
          "default": null

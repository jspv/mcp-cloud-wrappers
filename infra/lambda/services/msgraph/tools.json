  {
    "name": "manage_draft",
    "description": "Update and/or send a draft. Provide fields to update, set send=True to send.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "to": {
          "type": "array",
          "items": {
            "type": "string"
          },

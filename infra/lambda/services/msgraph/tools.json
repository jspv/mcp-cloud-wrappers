[
  {
    "name": "auth_status",
    "description": "Show current Microsoft auth configuration and cached accounts.\n\nWhen running inside the MCP Lambda wrapper framework, reports\nframework-managed authentication status instead of local MSAL state."
  },
  {
    "name": "start_auth",
    "description": "Start Microsoft authentication.\n\nIn Lambda mode, returns an OAuth authorization URL.\nIn local mode, starts the device-code flow."
  },
  {
    "name": "finish_auth",
    "description": "Complete Microsoft authentication after user approval.\n\nIn Lambda mode, this is not needed \u2014 call auth_status instead.\nIn local mode, completes the device-code flow."
  },
  {
    "name": "list_folders",
    "description": "List mail folders. Pass parent_folder_id to list subfolders (check child_folder_count to know if subfolders exist).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "default": null
        },
        "include_hidden": {
          "default": false,
          "type": "boolean"
        },
        "parent_folder_id": {
          "type": "string",
          "default": null
        }
      }
    }
  },
  {
    "name": "list_messages",
    "description": "List recent mail messages from a folder.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "default": null
        },
        "folder": {
          "default": "inbox",
          "type": "string"
        },
        "limit": {
          "default": 10,
          "type": "integer"
        }
      }
    }
  },
  {
    "name": "get_message",
    "description": "Get a full read-only view of a specific mail message.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "update_message",
    "description": "Update message properties: read/unread, follow-up flag (flagged/complete/notFlagged), or color categories.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "is_read": {
          "type": "boolean",
          "default": null
        },
        "flag_status": {
          "type": "string",
          "default": null
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": null
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "move_message",
    "description": "Move a message to another folder. Requires Mail.ReadWrite permission.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "message_id",
        "destination"
      ]
    }
  },
  {
    "name": "delete_message",
    "description": "Delete a message or move it to Deleted Items. Requires Mail.ReadWrite permission.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "account_id": {
          "type": "string",
          "default": null
        },
        "permanent": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "search_messages",
    "description": "Search messages using Microsoft Graph message search.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "account_id": {
          "type": "string",
          "default": null
        },
        "limit": {
          "default": 10,
          "type": "integer"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  {
    "name": "bulk_manage_messages",
    "description": "Bulk-manage messages with filtering. Supports dry-run, delete, move, and mark-read actions.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "default": null
        },
        "folder": {
          "default": "inbox",
          "type": "string"
        },
        "sender_contains": {
          "type": "string",
          "default": null
        },
        "subject_contains": {
          "type": "string",
          "default": null
        },
        "received_after": {
          "type": "string",
          "default": null
        },
        "unread_only": {
          "default": false,
          "type": "boolean"
        },
        "action": {
          "default": "delete",
          "type": "string"
        },
        "destination": {
          "type": "string",
          "default": null
        },
        "limit": {
          "default": 50,
          "type": "integer"
        },
        "max_passes": {
          "default": 5,
          "type": "integer"
        },
        "dry_run": {
          "default": true,
          "type": "boolean"
        }
      }
    }
  },
  {
    "name": "list_calendars",
    "description": "List readable calendars. Pass user_id for shared calendars (e.g. another user's email or object ID).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "default": null
        },
        "user_id": {
          "type": "string",
          "default": null
        }
      }
    }
  },
  {
    "name": "list_events",
    "description": "List events from a calendar in a time range. Pass user_id for shared calendars.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "default": null
        },
        "start_iso": {
          "type": "string",
          "default": null
        },
        "end_iso": {
          "type": "string",
          "default": null
        },
        "calendar_id": {
          "type": "string",
          "default": null
        },
        "limit": {
          "default": 25,
          "type": "integer"
        },
        "user_id": {
          "type": "string",
          "default": null
        }
      }
    }
  },
  {
    "name": "get_event",
    "description": "Get full details for a specific calendar event. Pass user_id for shared calendars.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "event_id": {
          "type": "string"
        },
        "account_id": {
          "type": "string",
          "default": null
        },
        "user_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "event_id"
      ]
    }
  },
  {
    "name": "send_message",
    "description": "Compose and send an email. Defaults to dry-run (preview only). Set dry_run=False to actually send.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "to": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "subject": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "cc": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": null
        },
        "bcc": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": null
        },
        "send_as": {
          "type": "string",
          "default": null
        },
        "dry_run": {
          "default": true,
          "type": "boolean"
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "to",
        "subject",
        "body"
      ]
    }
  },
  {
    "name": "reply_to_message",
    "description": "Reply to a message. Defaults to dry-run (preview only). Set dry_run=False to actually send.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "reply_all": {
          "default": false,
          "type": "boolean"
        },
        "send_as": {
          "type": "string",
          "default": null
        },
        "dry_run": {
          "default": true,
          "type": "boolean"
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "message_id",
        "body"
      ]
    }
  },
  {
    "name": "forward_message",
    "description": "Forward a message. Defaults to dry-run (preview only). Set dry_run=False to actually send.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "to": {
          "items": {
            "type": "string"

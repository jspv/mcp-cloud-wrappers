        "body": {
          "type": "string",
          "default": null
        },
        "send_as": {
          "type": "string",
          "default": null
        },
        "dry_run": {
          "default": true,
          "type": "boolean"
        },
        "account_id": {
          "type": "string",
          "default": null
        }
      },
      "required": [
        "message_id",
        "to"
      ]
    }
  },
  {
    "name": "create_draft",
    "description": "Create a draft email without sending it.",

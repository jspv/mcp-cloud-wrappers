[
  {
    "name": "auth_status",
    "description": "Show current Microsoft auth configuration and cached accounts.\n\nWhen running inside the MCP Lambda wrapper framework, reports\nframework-managed authentication status instead of local MSAL state."
  },
  {
    "name": "start_auth",
    "description": "Start Microsoft authentication.\n\nIn Lambda mode, returns an OAuth authorization URL.\nIn local mode, starts the device-code flow."
  },
  {
    "name": "finish_auth",
    "description": "Complete Microsoft authentication after user approval.\n\nIn Lambda mode, this is not needed \u2014 call auth_status instead.\nIn local mode, completes the device-code flow."
  },
  {
    "name": "list_accounts",
    "description": "List authenticated Microsoft accounts.\n\nIn Lambda mode, returns the framework-managed account info."
  },
  {
    "name": "list_folders",
    "description": "List available mail folders for the authenticated account.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "include_hidden": {
          "default": false,
          "type": "boolean"
        }
      }
    }
  },
  {
    "name": "list_messages",
    "description": "List recent mail messages from a folder.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "folder": {
          "default": "inbox",
          "type": "string"
        },
        "limit": {
          "default": 10,
          "type": "integer"
        }
      }
    }
  },
  {
    "name": "get_message",
    "description": "Get a full read-only view of a specific mail message.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "mark_message_read",
    "description": "Mark a message as read or unread. Requires Mail.ReadWrite permission.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "is_read": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "move_message",
    "description": "Move a message to another folder. Requires Mail.ReadWrite permission.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "message_id",
        "destination"
      ]
    }
  },
  {
    "name": "delete_message",
    "description": "Delete a message or move it to Deleted Items. Requires Mail.ReadWrite permission.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "permanent": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "message_id"
      ]
    }
  },
  {
    "name": "search_messages",
    "description": "Search messages using Microsoft Graph message search.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": 10,
          "type": "integer"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  {
    "name": "bulk_manage_messages",
    "description": "Bulk-manage messages with filtering. Supports dry-run, delete, move, and mark-read actions.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "folder": {
          "default": "inbox",
          "type": "string"
        },
        "sender_contains": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "subject_contains": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "received_after": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "unread_only": {
          "default": false,
          "type": "boolean"
        },
        "action": {
          "default": "delete",
          "type": "string"
        },
        "destination": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": 50,
          "type": "integer"
        },
        "max_passes": {
          "default": 5,
          "type": "integer"
        },
        "dry_run": {
          "default": true,
          "type": "boolean"
        }
      }
    }
  },
  {
    "name": "list_calendars",
    "description": "List readable calendars for the authenticated account.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    }
  },
  {
    "name": "list_events",
    "description": "List events from the default or specified calendar in a time range.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "start_iso": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "end_iso": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "calendar_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": 25,
          "type": "integer"
        }
      }
    }
  },
  {
    "name": "get_event",
    "description": "Get full details for a specific calendar event.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "event_id": {
          "type": "string"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "event_id"
      ]
    }
  }
]

# Non-secret configuration for the msgraph service.
# These values are loaded into the Lambda environment at startup
# and passed through to the MCP subprocess.

# --- Framework settings (used by CDK at deploy time) ---
# Lambda timeout in seconds (default: 120)
LAMBDA_TIMEOUT=120
# Lambda memory in MB (default: 512)
LAMBDA_MEMORY=512

# --- Service settings (passed to the MCP subprocess) ---
# Azure AD tenant: "organizations" (any work/school), "common" (any account),
# "consumers" (personal only), or a specific tenant ID.
MICROSOFT_TENANT_ID=organizations
